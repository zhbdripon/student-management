# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5433
DB_NAME=student_management

# Constructed from the individual vars above
DATABASE_URL="postgresql://postgres:your_password@localhost:5433/student_management?schema=public"

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="add_your_secret_here"
BETTER_AUTH_URL="http://localhost:3000"